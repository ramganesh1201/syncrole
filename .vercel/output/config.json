{
  "version": 3,
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/assets/(.*)"
    },
    {
      "handle": "error"
    },
    {
      "status": 404,
      "src": "^(?!/api).*$",
      "dest": "/404.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/__server"
    }
  ],
  "overrides": {},
  "framework": {
    "slug": "tanstack-start",
    "version": "1.168.18"
  },
  "crons": []
}
